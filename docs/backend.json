
{
  "entities": {
    "Asset": {
      "title": "Asset",
      "type": "object",
      "description": "Represents a piece of equipment at a site.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "assetTag": { "type": "string" },
        "serialNumber": { "type": "string" },
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "siteId": { "type": "string" },
        "locationDescription": { "type": "string" },
        "installDate": { "type": "string", "format": "date-time" },
        "warrantyExpiration": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "retired", "out_of_service"] },
        "criticality": { "type": "string", "enum": ["low", "medium", "high"] },
        "expectedLifeYears": { "type": "number" },
        "replacementCost": { "type": "number" },
        "lastServiceDate": { "type": "string", "format": "date-time" },
        "nextServiceDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "assetTag", "siteId", "status", "criticality"]
    },
    "Material": {
      "title": "Material",
      "type": "object",
      "description": "A part or material used in preventative maintenance (e.g. Belts, Filters).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "partNumber": { "type": "string" },
        "description": { "type": "string" },
        "uom": { "type": "string" },
        "customFields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "category", "uom"]
    },
    "PmTemplate": {
      "title": "PmTemplate",
      "type": "object",
      "description": "Definition of a preventative maintenance task.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "frequencyType": { "type": "string", "enum": ["monthly", "quarterly", "semiannual", "annual", "custom_days"] },
        "customIntervalDays": { "type": "number" },
        "estimatedLaborHours": { "type": "number" },
        "requiredMaterials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "materialId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "uom": { "type": "string" }
            }
          }
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "string" },
              "requiresPhoto": { "type": "boolean" },
              "requiresMeasurement": { "type": "boolean" }
            }
          }
        },
        "safetyNotes": { "type": "string" },
        "complianceCategory": { "type": "string" }
      },
      "required": ["id", "name", "frequencyType", "estimatedLaborHours"]
    },
    "AssetPmSchedule": {
      "title": "AssetPmSchedule",
      "type": "object",
      "description": "A scheduled PM for a specific asset.",
      "properties": {
        "id": { "type": "string" },
        "assetId": { "type": "string" },
        "templateId": { "type": "string" },
        "nextDueDate": { "type": "string", "format": "date-time" },
        "lastCompletedDate": { "type": "string", "format": "date-time" },
        "autoGenerateWorkOrder": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "paused"] }
      },
      "required": ["assetId", "templateId", "nextDueDate", "status"]
    },
    "AssetServiceHistory": {
      "title": "AssetServiceHistory",
      "type": "object",
      "description": "Historical record of service for an asset.",
      "properties": {
        "id": { "type": "string" },
        "assetId": { "type": "string" },
        "workOrderId": { "type": "string" },
        "technicianId": { "type": "string" },
        "completedDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "materialsUsed": { "type": "array" },
        "measurements": { "type": "object" },
        "photos": { "type": "array" },
        "followUpRequired": { "type": "boolean" }
      },
      "required": ["assetId", "workOrderId", "completedDate", "notes"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/assets/{assetId}",
        "definition": { "entityName": "Asset" }
      },
      {
        "path": "/materials/{materialId}",
        "definition": { "entityName": "Material" }
      },
      {
        "path": "/pm_templates/{templateId}",
        "definition": { "entityName": "PmTemplate" }
      },
      {
        "path": "/asset_pm_schedules/{scheduleId}",
        "definition": { "entityName": "AssetPmSchedule" }
      },
      {
        "path": "/asset_service_history/{historyId}",
        "definition": { "entityName": "AssetServiceHistory" }
      }
    ]
  }
}
