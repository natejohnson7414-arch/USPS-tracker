
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'admin@crawford-company.com' || userHasRole('Administrator'));
    }

    function userHasRole(roleName) {
      let userDoc = get(/databases/$(database)/documents/technicians/$(request.auth.uid));
      return isSignedIn() && userDoc.data != null && userDoc.data.roleId != null &&
        get(/databases/$(database)/documents/roles/$(userDoc.data.roleId)).data.name == roleName;
    }

    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pm_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /asset_pm_schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /asset_service_history/{historyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /work_orders/{workOrderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /technicians/{techId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /work_sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
