
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'admin@crawford-company.com' || userHasRole('Administrator'));
    }

    function userHasRole(roleName) {
      let userDocPath = /databases/$(database)/documents/technicians/$(request.auth.uid);
      return isSignedIn() && exists(userDocPath) && get(userDocPath).data.roleId != null &&
        get(/databases/$(database)/documents/roles/$(get(userDocPath).data.roleId)).data.name == roleName;
    }

    // PM System
    match /pm_task_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /pm_work_orders/{workOrderId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Collection Group rule for PM Schedules
    match /{path=**}/pmSchedules/{scheduleId} {
      allow read, write: if isSignedIn();
    }

    // Collection Group rule for Activities (Crucial for Dashboard)
    match /{path=**}/activities/{activityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Quotes: Accessible to all authenticated users for field submissions
    match /quotes/{quoteId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Asset Management
    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /pmSchedules/{scheduleId} {
        allow read, write: if isSignedIn();
      }
    }

    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /pm_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /asset_pm_schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /asset_service_history/{historyId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Work Orders & Core
    match /work_orders/{workOrderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();

      match /updates/{updateId} {
        allow read, write: if isSignedIn();
      }
      match /activities/{activityId} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /technicians/{techId} {
      allow read: if isSignedIn();
      // Allow users to update their own profile (for settings like defaultDispatchView)
      allow update: if isSignedIn() && (request.auth.uid == techId || isAdmin());
      allow create, delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /work_sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /hvac_startup_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /training_records/{recordId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /time_entries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
