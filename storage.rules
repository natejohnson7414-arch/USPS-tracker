rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Robust rule for all application documentation and field media.
    // Allows any authenticated user to perform read/write operations.
    // This resolves 'Access Denied' issues caused by complex path matching 
    // in workstation environments.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
