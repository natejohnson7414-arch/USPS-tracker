
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    /**
     * Helper function to check if the authenticated user has a specific role.
     * This performs a `get()` call to Firestore to check the user's role document.
     */
    function userHasRole(roleName) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userDoc = get(userDocPath);
      return request.auth != null && userDoc.data.roleId != null &&
        get(/databases/$(database)/documents/roles/$(userDoc.data.roleId)).data.name == roleName;
    }

    /**
     * Checks if the user is an Administrator.
     */
    function isAdmin() {
      // An email check is included as a fallback, similar to firestore.rules
      return request.auth != null && (request.auth.token.email == 'admin@crawford-company.com' || userHasRole('Administrator'));
    }
    
     /**
     * Checks if the user is a Technician.
     */
    function isTechnician() {
      return userHasRole('Technician');
    }
    
    /**
     * Checks if the parent work order is in a completed state.
     */
     function isWorkOrderCompleted(workOrderId) {
        let workOrderPath = /databases/$(database)/documents/work_orders/$(workOrderId);
        return get(workOrderPath).data.status == 'Completed';
     }

    /**
     * @description Secures all files related to work orders.
     * @path /work-orders/{workOrderId}/{allPaths=**}
     * @allow (read) Any authenticated user.
     * @allow (write) Any authenticated user if the parent work order is not completed, or if the user is an admin.
     * @principle Enforces that photos for completed work orders are immutable for non-admins.
     */
    match /work-orders/{workOrderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAdmin() || !isWorkOrderCompleted(workOrderId));
    }
  }
}
