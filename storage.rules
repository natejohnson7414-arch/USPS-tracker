rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Top-level prioritized rule for Quotes to ensure reliable preflight
    // Explicitly allows all authenticated users to read/write quote media
    match /quotes/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    function userHasRole(roleName) {
      let userDocPath = /databases/$(database)/documents/technicians/$(request.auth.uid);
      let userDoc = get(userDocPath);
      return isSignedIn() && userDoc.data != null && userDoc.data.roleId != null &&
        get(/databases/$(database)/documents/roles/$(userDoc.data.roleId)).data.name == roleName;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'admin@crawford-company.com' || userHasRole('Administrator'));
    }

    match /work-orders/{workOrderId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /signatures/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /assets/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
